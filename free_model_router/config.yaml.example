# =============================================================================
# free-model-router 配置文件示例
# =============================================================================
#
# 核心特性:
#   ✓ 不限制固定模型 — 启动时从每个 provider 拉取 /v1/models 自动发现
#   ✓ 一个 provider 支持多个 API key 自动轮询
#   ✓ 4 种免费模型识别策略: all / pattern / include / exclude
#   ✓ 自动故障转移: 401/404 禁用模型, 429 限流等待, 5xx 自动重试
#   ✓ 健康检查 + 自动恢复
#   ✓ 配置热重载 (改完保存自动生效)
#
# 启动:  python -m free_model_router --config config.yaml
# =============================================================================

server:
  host: "127.0.0.1"            # 监听地址, 0.0.0.0 = 允许外部访问
  port: 5678                    # 监听端口
  api_key: ""                   # 网关鉴权, 留空不鉴权, 客户端需带: Authorization: Bearer <key>
  cors_origins: ["*"]           # CORS 白名单

routing:
  strategy: "random"           # random | round-robin | least-loaded
  max_retry: 2                 # 单个请求最多切换几个 provider
  first_token_timeout: 10000    # 流式首字节超时 (ms)
  request_timeout: 60000       # 非流式请求总超时 (ms)

sync:
  auto_discover: true          # 启动时自动从 /v1/models 拉取
  interval: 3600               # 定时刷新间隔 (秒), 0 = 禁用

# ─────────────────────────────────────────────────────────────────────────────
# Providers
# ─────────────────────────────────────────────────────────────────────────────
# 每个 provider 必须配置:
#   base_url:     上游 API 根地址 (不要带 /chat/completions)
#   api_keys:     API key 列表 (可多个, 自动轮询 + 失败切换)
#   model_rules:  免费模型识别规则
#   enabled:      是否启用
#   max_concurrent: 最大并发槽位数
#
# model_rules.mode 取值:
#   - "all":       所有模型都视为免费 (无固定模型限制)
#   - "pattern":   正则匹配, 仅保留匹配的 (例: ".*free.*", ".*-turbo")
#   - "include":   白名单, 仅列出的 ID 才视为免费
#   - "exclude":   黑名单, 列出的 ID 不视为免费 (支持 glob: * ? [...])
# ─────────────────────────────────────────────────────────────────────────────

providers:

  # ─────────── 例子 1: OpenRouter (按 "free" 关键字) ───────────
  openrouter:
    base_url: "https://openrouter.ai/api/v1"
    api_keys:
      - "sk-or-v1-xxxxxxxxxxxxxxxx"
      - "sk-or-v1-yyyyyyyyyyyyyyyy"     # ← 多个 key 轮询
    model_rules:
      mode: "pattern"
      pattern: ".*free.*"               # ← 含 "free" 的模型视为免费
    max_concurrent: 3
    enabled: true
    # headers:                            # 可选: 自定义请求头
    #   HTTP-Referer: "https://mysite.com"
    #   X-Title: "my-app"

  # ─────────── 例子 2: 智谱 (白名单) ───────────
  zhipu:
    base_url: "https://open.bigmodel.cn/api/paas/v4"
    api_keys:
      - "智谱 API key"
    model_rules:
      mode: "include"
      include:
        - "glm-4-flash"
        - "glm-4-flash-250414"
        - "glm-4-flashx"
    max_concurrent: 5
    enabled: true

  # ─────────── 例子 3: 自建中转 (排除付费) ───────────
  custom-relay:
    base_url: "https://api.example.com/v1"
    api_keys:
      - "sk-relay-1"
      - "sk-relay-2"                     # ← 多 key 轮询
      - "sk-relay-3"
    model_rules:
      mode: "exclude"
      exclude:
        - "gpt-4*"
        - "gpt-4o*"
        - "claude-3*"
        - "claude-opus*"
        - "o1*"
        - "o3*"
    max_concurrent: 4
    enabled: true

  # ─────────── 例子 4: 不限制 (全部免费) ───────────
  free-for-all:
    base_url: "https://api.example.com/v1"
    api_keys:
      - "sk-xxx"
    model_rules:
      mode: "all"                        # ← 全部模型都视为免费
    max_concurrent: 2
    enabled: true

  # ─────────── 例子 5: 关闭的 provider ───────────
  disabled-provider:
    base_url: "https://api.disabled.com/v1"
    api_keys:
      - "sk-xxx"
    model_rules:
      mode: "all"
    enabled: false                        # ← 不会被路由到
